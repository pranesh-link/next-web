    "postcss": "^8",
    "tsx": "^4.19.2",
    "turbo": "^2",
    "typescript": "~5.8"
  },
  "resolutions": {
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.5"
  }
}
