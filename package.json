{
  "name": "next-web",
  "description": "Personal monorepo: portfolio site + LuvVerse couple platform (web & Flutter mobile)",
  "version": "3.22.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "SKIP_DB_BACKUP=true npx prisma migrate deploy && tsc --noEmit && next dev -p 3737 --hostname 0.0.0.0",
    "db:backup": "npx tsx scripts/db-backup.ts",
    "db:restore": "npx tsx scripts/db-restore.ts",
    "db:restore:latest": "npx tsx scripts/db-restore.ts --confirm latest",
    "db:safe-migrate": "npx tsx scripts/safe-migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "build": "node scripts/validate-env.mjs && rm -rf .next && next build --no-lint",
    "build:with-migrate": "node scripts/validate-env.mjs && npm run db:safe-migrate && rm -rf .next && next build --no-lint",
    "build:analyze": "ANALYZE=true npm run build",
    "vercel-build": "node scripts/validate-env.mjs && next build --no-lint",
    "start": "next start -p 3737",
    "lint": "next lint",
    "serve": "next build && next start -p 3737",
    "prod": "lsof -ti:3737 | xargs kill -9 2>/dev/null || true && npm run build && npm start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "husky"
  },
  "husky": {
    "hooks": {
      "pre-commit": "next build"
    }
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.7.4",
    "@auth/prisma-adapter": "^2.11.1",
    "@emailjs/browser": "4.3.3",
    "@google/genai": "^1.46.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@prisma/extension-accelerate": "^2.0.2",
    "@reduxjs/toolkit": "2.2.4",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "1.2.2",
    "@vercel/speed-insights": "1.0.10",
    "axios": "^1.13.1",
    "classnames": "2.5.1",
    "crypto-js": "4.2.0",
    "drizzle-orm": "^0.43.1",
    "@supabase/supabase-js": "^2.49.4",
    "firebase-admin": "^13.4.0",
    "jsonwebtoken": "^9.0.3",
    "lodash": "4.17.21",
    "lucide-react": "^1.14.0",
    "mobile-detect": "1.4.5",
    "mongoose": "8.4.0",
    "next": "15.3.8",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.32.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "react": "19.1.0",
    "react-copy-to-clipboard": "5.1.0",
    "react-device-detect": "2.2.3",
    "react-dom": "19.1.0",
    "react-gauge-chart": "0.4.1",
    "react-modal": "3.16.1",
    "react-phone-number-input": "3.3.9",
    "react-redux": "9.1.2",
    "react-select": "^5.10.2",
    "react-transition-group": "4.4.5",
    "recharts": "^3.8.0",
    "redux": "5.0.1",
    "sass": "1.72.0",
    "sharp": "0.33.3",
    "styled-components": "6.1.8",
    "tailwindcss": "3.4.1",
    "tesseract.js": "^7.0.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@swc/plugin-styled-components": "1.5.118",
    "drizzle-kit": "^0.31.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/classnames": "2.3.1",
    "@types/crypto-js": "4.2.2",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "4.14.202",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "19.1.6",
    "@types/react-copy-to-clipboard": "5.0.7",
    "@types/react-dom": "19.1.5",
    "@types/react-gauge-chart": "0.4.3",
    "@types/react-modal": "3.16.3",
    "@types/react-transition-group": "4.4.10",
    "@types/styled-components": "5.1.34",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "15.3.2",
    "husky": "9.0.11",
    "jest": "^29.7.0",
