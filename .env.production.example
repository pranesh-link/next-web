# Production Environment Variables
# Copy this file to .env.production and fill in your values

# MongoDB Connection (required for dynamic data)
MONGODB_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/your-database?retryWrites=true&w=majority

# Next.js Configuration
NODE_ENV=production
NEXT_PUBLIC_DISABLE_PWA=false

# Optional: Analytics
NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id

# Optional: Contact Form (EmailJS)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your-service-id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your-template-id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your-public-key

# Performance Tips:
# - Ensure MongoDB connection string includes retryWrites=true
# - Add your IP to MongoDB Atlas whitelist to prevent timeouts
# - Use connection pooling (configured in database.js)
# - Enable CDN for static assets
# - Configure proper caching headers (already set in next.config.mjs)
