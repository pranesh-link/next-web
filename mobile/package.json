{
  "name": "@next-web/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:ios": "expo start --ios",
    "dev:android": "expo start --android",
    "build:dev": "eas build --profile development --platform all",
    "build:beta": "eas build --profile beta --platform all",
    "build:beta:ios": "eas build --profile beta --platform ios",
    "build:beta:android": "eas build --profile beta --platform android",
    "build:production": "eas build --profile production --platform all",
    "submit:beta:ios": "eas submit --profile beta --platform ios",
    "submit:beta:android": "eas submit --profile beta --platform android",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@next-web/shared": "file:../packages/shared",
    "@next-web/ui": "file:../packages/ui",
    "@react-native-google-signin/google-signin": "^13.1.0",
    "@tamagui/config": "^1.115.0",
    "@tamagui/lucide-icons": "^1.115.0",
    "@tanstack/react-query": "^5.60.0",
    "expo": "~54",
    "expo-auth-session": "~7.0.11",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-worklets": "~0.5.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "tamagui": "^1.115.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@tamagui/babel-plugin": "^1.115.0",
    "@types/node": "^22.0.0",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "electron-to-chromium": "1.5.137"
  }
