// Personal CFO — Prisma Schema
// All models use UUID primary keys with proper relations and indexes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ────────────────────────────────────────

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Core Models ────────────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  name           String?
  email          String   @unique
  emailVerified  DateTime?
  image          String?
  currency       String   @default("INR")
  monthlyIncome  Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // NextAuth relations
  accounts_auth  Account[]
  sessions       Session[]

  // Finance relations
  accounts       FinancialAccount[]
  transactions   Transaction[]
  budgets        Budget[]
  loans          Loan[]
  savingsGoals   SavingsGoal[]
  budgetPlans    BudgetPlan[]
  investments    InvestmentHolding[]
  deposits       DepositInstrument[]

  // Couple relations
  coupleMembers  CoupleMember[]

  // Notification relations
  notifications  Notification[]

  @@map("users")
}

model FinancialAccount {
  id              String   @id @default(uuid())
  userId          String
  name            String
  type            AccountType
  balance         Float    @default(0)
  isSalaryAccount Boolean  @default(false)
  isEmergencyFund Boolean  @default(false)
  isPinned        Boolean  @default(false)
  coupleId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  balanceHistory BalanceHistory[]

  @@index([userId])
  @@map("financial_accounts")
}

model BalanceHistory {
  id        String   @id @default(uuid())
  accountId String
  balance   Float
  change    Float
  note      String?
  userId    String
  coupleId  String?
  createdAt DateTime @default(now())

  account FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([userId])
  @@map("balance_history")
}

enum AccountType {
  SAVINGS_ACCOUNT
  CREDIT_ACCOUNT
  CREDIT_CARD
  RECURRING_DEPOSIT
  FIXED_DEPOSIT
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String
  accountId   String
  amount      Float
  type        TransactionType
  category    String
  description String?
  date        DateTime
  coupleId    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  account FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
  @@index([userId, category])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum InvestmentAssetType {
  GOLD
  SILVER
  STOCK
  MUTUAL_FUND
}

enum InvestmentMode {
  LUMPSUM
  SIP
}

enum StockExchange {
  NSE
  BSE
}

enum DepositType {
  RECURRING_DEPOSIT
  FIXED_DEPOSIT
}

enum DepositStatus {
  ACTIVE
  MATURED
}

enum InstallmentStatus {
  PENDING
  PAID
  MISSED
}

model InvestmentHolding {
  id              String              @id @default(uuid())
  userId          String
  coupleId        String?
  name            String
  assetType       InvestmentAssetType
  mode            InvestmentMode      @default(LUMPSUM)
  ticker          String?
  exchange        StockExchange?
  quantity        Float?
  quantityGrams   Float?
  investedAmount  Float
  currentPrice    Float?
  currentValue    Float?
  sipAmount       Float?
  sipDayOfMonth   Int?
  startDate       DateTime
  nextSipDate     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assetType])
  @@index([nextSipDate])
  @@map("investment_holdings")
}

model DepositInstrument {
  id                   String          @id @default(uuid())
  userId               String
  coupleId             String?
  name                 String
  provider             String?
  type                 DepositType
  principalAmount      Float
  interestRate         Float
  tenureMonths         Int
  installmentAmount    Float?
  paidInstallments     Int             @default(0)
  totalInstallments    Int?
  startDate            DateTime
  maturityDate         DateTime
  maturityAmount       Float
  nextInstallmentDate  DateTime?
  status               DepositStatus   @default(ACTIVE)
  sourceAccountId      String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  installments DepositInstallment[]

  @@index([userId])
  @@index([type])
  @@index([maturityDate])
  @@index([nextInstallmentDate])
  @@index([sourceAccountId])
  @@map("deposit_instruments")
}

model DepositInstallment {
  id         String            @id @default(uuid())
  depositId  String
  amount     Float
  dueDate    DateTime
  paidDate   DateTime?
  status     InstallmentStatus @default(PENDING)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  deposit DepositInstrument @relation(fields: [depositId], references: [id], onDelete: Cascade)

  @@index([depositId])
  @@index([dueDate])
  @@map("deposit_installments")
}

model Budget {
  id       String @id @default(uuid())
  userId   String
  category String
  limit    Float
  month    String // "2026-03" format
  coupleId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, month])
  @@index([userId])
  @@index([userId, month])
  @@map("budgets")
}

model Loan {
  id               String   @id @default(uuid())
  userId           String
  name             String
  principal        Float
  interestRate     Float
  tenureMonths     Int
  emiAmount        Float
  startDate        DateTime
  remainingBalance Float
  prepayments         Json?
  schedule            Json?
  loanAccountNumber   String? @map("loan_account_number")
  scheduleGeneratedOn String? @map("schedule_generated_on")
  loanProvider        String? @map("loan_provider")
  coupleId            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("loans")
}

model SavingsGoal {
  id            String    @id @default(uuid())
  userId        String
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  deadline      DateTime?
  coupleId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("savings_goals")
}

// ─── Couple Models ──────────────────────────────────────────

model Couple {
  id        String         @id @default(uuid())
  name      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  members   CoupleMember[]
  invites   CoupleInvite[]
}

model CoupleMember {
  id        String   @id @default(uuid())
  coupleId  String
  userId    String
  role      String   @default("OWNER")
  joinedAt  DateTime @default(now())
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([coupleId, userId])
  @@map("couple_members")
}

model CoupleInvite {
  id        String   @id @default(uuid())
  coupleId  String
  email     String
  invitedBy String
  token     String   @unique @default(uuid())
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@map("couple_invites")
}

// ─── Budget Plan Models ─────────────────────────────────────

model BudgetPlan {
  id           String   @id @default(uuid())
  userId       String
  monthAndYear String   @map("month_and_year") // "2026-04" or "2026" format
  mode         String   @default("monthly") // "monthly" | "yearly"
  income       Float
  lineItems    Json     // [{category: string, amount: number, note?: string}]
  coupleId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, monthAndYear, mode])
  @@index([userId])
  @@map("budget_plans")
}

// ─── Notification Models ────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   @default("COUPLE_INVITE")
  featureId String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([featureId])
  @@map("notifications")
}
