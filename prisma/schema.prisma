// Personal CFO — Prisma Schema
// All models use UUID primary keys with proper relations and indexes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ────────────────────────────────────────

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Core Models ────────────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  name           String?
  email          String   @unique
  emailVerified  DateTime?
  image          String?
  currency       String   @default("INR")
  monthlyIncome  Float?
  /// Base64-encoded JWK ECDH public key for E2E message encryption.
  publicKey      String?  @db.Text
  /// Monotonically-increasing version counter. Bumped on key rotation
  /// (e.g. device reinstall causing private-key loss).
  keyVersion     Int      @default(1)
  /// Timestamp of the most recent key rotation (null = never rotated).
  keyRotatedAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // NextAuth relations
  accounts_auth  Account[]
  sessions       Session[]

  // Finance relations
  accounts       FinancialAccount[]
  transactions   Transaction[]
  budgets        Budget[]
  loans          Loan[]
  savingsGoals   SavingsGoal[]
  budgetPlans    BudgetPlan[]
  budgetPlansLastUpdated BudgetPlan[] @relation("BudgetPlanLastUpdatedBy")
  investments    InvestmentHolding[]
  deposits       DepositInstrument[]

  // Couple relations
  coupleMembers  CoupleMember[]

  // Notification relations
  notifications  Notification[]
  deviceTokens   DeviceToken[]

  // Lifestyle / Wellness relations
  bodyMetricsCreated  BodyMetric[]  @relation("BodyMetricCreator")
  bodyMetricsSubject  BodyMetric[]  @relation("BodyMetricSubject")
  bodyProfileCreated  BodyProfile[] @relation("BodyProfileCreator")
  bodyProfileSubject  BodyProfile?  @relation("BodyProfileSubject")

  // Lifestyle relations
  nutritionLogs    NutritionLog[]
  exerciseLogs     ExerciseLog[]
  sleepLogs        SleepLog[]
  habits           Habit[]
  habitLogs        HabitLog[]

  // Travel relations
  trips            Trip[]

  @@map("users")
}

model FinancialAccount {
  id              String   @id @default(uuid())
  userId          String
  name            String
  nickname        String?
  type            AccountType
  balance         Float    @default(0)
  isSalaryAccount Boolean  @default(false)
  isEmergencyFund Boolean  @default(false)
  isPinned        Boolean  @default(false)
  coupleId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  balanceHistory BalanceHistory[]

  @@index([userId])
  @@map("financial_accounts")
}

model BalanceHistory {
  id        String   @id @default(uuid())
  accountId String
  balance   Float
  change    Float
  note      String?
  userId    String
  coupleId  String?
  createdAt DateTime @default(now())

  account FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([userId])
  @@map("balance_history")
}

enum AccountType {
  SAVINGS_ACCOUNT
  CREDIT_ACCOUNT
  CREDIT_CARD
  RECURRING_DEPOSIT
  FIXED_DEPOSIT
}

enum BalanceChangeReason {
  ACCOUNT_ADDED
  ACCOUNT_REMOVED
  BALANCE_UPDATED
}

model OverallBalanceLog {
  id           String              @id @default(uuid())
  coupleId     String?
  userId       String
  accountId    String?
  accountName  String
  reason       BalanceChangeReason
  change       Float
  totalBalance Float
  createdAt    DateTime            @default(now())

  @@index([coupleId])
  @@index([userId])
  @@map("overall_balance_log")
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String
  accountId   String
  amount      Float
  type        TransactionType
  category    String
  description   String?
  receiptSource String?
  date          DateTime
  coupleId      String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  account FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
  @@index([userId, category])
  @@index([userId, date(sort: Desc)], map: "transactions_userId_date_desc_idx")
  @@index([accountId, date])
  @@index([userId, category, date])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum InvestmentAssetType {
  GOLD
  SILVER
  STOCK
  MUTUAL_FUND
}

enum InvestmentMode {
  LUMPSUM
  SIP
}

enum StockExchange {
  NSE
  BSE
}

enum DepositType {
  RECURRING_DEPOSIT
  FIXED_DEPOSIT
}

enum DepositStatus {
  ACTIVE
  MATURED
}

enum DepositInstallmentFrequency {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum InstallmentStatus {
  PENDING
  PAID
  MISSED
}

model InvestmentHolding {
  id              String              @id @default(uuid())
  userId          String
  coupleId        String?
  name            String
  assetType       InvestmentAssetType
  mode            InvestmentMode      @default(LUMPSUM)
  ticker          String?
  exchange        StockExchange?
  quantity        Float?
  quantityGrams   Float?
  investedAmount  Float
  currentPrice    Float?
  currentValue    Float?
  sipAmount       Float?
  sipDayOfMonth   Int?
  startDate       DateTime
  nextSipDate     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assetType])
  @@index([nextSipDate])
  @@map("investment_holdings")
}

model DepositInstrument {
  id                   String          @id @default(uuid())
  userId               String
  coupleId             String?
  name                 String
  provider             String?
  type                 DepositType
  principalAmount      Float
  interestRate         Float
  tenureMonths         Int
  installmentAmount    Float?
  installmentFrequency DepositInstallmentFrequency @default(MONTHLY)
  paidInstallments     Int             @default(0)
  totalInstallments    Int?
  startDate            DateTime
  maturityDate         DateTime
  maturityAmount       Float
  nextInstallmentDate  DateTime?
  status               DepositStatus   @default(ACTIVE)
  sourceAccountId      String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  installments DepositInstallment[]

  @@index([userId])
  @@index([type])
  @@index([maturityDate])
  @@index([nextInstallmentDate])
  @@index([sourceAccountId])
  @@map("deposit_instruments")
}

model DepositInstallment {
  id         String            @id @default(uuid())
  depositId  String
  amount     Float
  dueDate    DateTime
  paidDate   DateTime?
  status     InstallmentStatus @default(PENDING)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  deposit DepositInstrument @relation(fields: [depositId], references: [id], onDelete: Cascade)

  @@index([depositId])
  @@index([dueDate])
  @@map("deposit_installments")
}

model Budget {
  id       String @id @default(uuid())
  userId   String
  category String
  limit    Float
  month    String // "2026-03" format
  coupleId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, month])
  @@index([userId])
  @@index([userId, month])
  @@map("budgets")
}

model Loan {
  id               String   @id @default(uuid())
  userId           String
  name             String
  principal        Float
  interestRate     Float
  tenureMonths     Int
  emiAmount        Float
  startDate        DateTime
  remainingBalance Float
  prepayments         Json?
  schedule            Json?
  loanAccountNumber   String? @map("loan_account_number")
  scheduleGeneratedOn String? @map("schedule_generated_on")
  loanProvider        String? @map("loan_provider")
  coupleId            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("loans")
}

model SavingsGoal {
  id            String    @id @default(uuid())
  userId        String
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  deadline      DateTime?
  coupleId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("savings_goals")
}

// ─── Lifestyle / Wellness Models ────────────────────────────

model BodyMetric {
  id           String   @id @default(uuid())
  userId       String
  subjectId    String   @map("subject_id")
  coupleId     String?  @map("couple_id")
  measuredOn   DateTime @map("measured_on") @db.Date
  weightInKg   Decimal  @map("weight_in_kg") @db.Decimal(5, 2)
  heightInCm   Decimal  @map("height_in_cm") @db.Decimal(5, 2)
  bmi          Decimal  @db.Decimal(4, 2)
  bmiCategory  String   @map("bmi_category")
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User @relation("BodyMetricCreator", fields: [userId], references: [id], onDelete: Cascade)
  subject User @relation("BodyMetricSubject", fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([subjectId, measuredOn])
  @@index([coupleId, measuredOn])
  @@index([subjectId, measuredOn])
  @@map("body_metrics")
}

model BodyProfile {
  id                String    @id @default(uuid())
  userId            String
  subjectId         String    @unique @map("subject_id")
  coupleId          String?   @map("couple_id")
  defaultHeightInCm Decimal?  @map("default_height_in_cm") @db.Decimal(5, 2)
  targetWeightInKg  Decimal?  @map("target_weight_in_kg") @db.Decimal(5, 2)
  birthDate         DateTime? @map("birth_date") @db.Date
  sex               String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user    User @relation("BodyProfileCreator", fields: [userId], references: [id], onDelete: Cascade)
  subject User @relation("BodyProfileSubject", fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([coupleId])
  @@map("body_profiles")
}

// ─── Couple Models ──────────────────────────────────────────

model Couple {
  id        String         @id @default(uuid())
  name      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  members   CoupleMember[]
  invites   CoupleInvite[]

  @@map("couples")
}

model CoupleMember {
  id        String    @id @default(uuid())
  coupleId  String
  userId    String
  role      String    @default("OWNER")
  joinedAt  DateTime  @default(now())
  typingAt  DateTime?
  couple    Couple    @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([coupleId, userId])
  @@map("couple_members")
}

model CoupleInvite {
  id        String   @id @default(uuid())
  coupleId  String
  email     String
  invitedBy String
  token     String   @unique @default(uuid())
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@map("couple_invites")
}

// ─── Budget Plan Models ─────────────────────────────────────

model BudgetPlan {
  id           String   @id @default(uuid())
  userId       String   // original creator
  monthAndYear String   @map("month_and_year") // "2026-04" or "2026" format
  mode         String   @default("monthly") // "monthly" | "yearly"
  income       Float
  lineItems    Json     // [{category: string, amount: number, note?: string, paid: boolean}]
  coupleId     String?
  lastUpdatedById String? @map("last_updated_by_id")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user          User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastUpdatedBy User? @relation("BudgetPlanLastUpdatedBy", fields: [lastUpdatedById], references: [id], onDelete: SetNull)

  // Note: previous unique constraint [userId, monthAndYear, mode] is dropped in
  // migration 20260509180000_budget_plan_couple_shared and replaced with two
  // partial unique indexes (couple-scoped vs solo-user) created via raw SQL.
  @@index([userId])
  @@index([coupleId])
  @@index([lastUpdatedById])
  @@index([userId, monthAndYear(sort: Desc)])
  @@map("budget_plans")
}

// ─── Notification Models ────────────────────────────────────

model Notification {
  id         String    @id @default(uuid())
  userId     String
  type       String    @default("COUPLE_INVITE")
  featureId  String?
  read       Boolean   @default(false)
  archived   Boolean   @default(false)
  payload    Json?
  createdAt  DateTime  @default(now())
  archivedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, featureId])
  @@index([userId])
  @@index([featureId])
  @@index([userId, archived])
  @@index([userId, archivedAt, createdAt(sort: Desc)])
  @@map("notifications")
}

// ─── Lifestyle: Nutrition ────────────────────────────────────

model NutritionLog {
  id           String   @id @default(uuid())
  userId       String
  coupleId     String?
  loggedOn     DateTime @db.Date
  mealType     String   // BREAKFAST | LUNCH | DINNER | SNACK
  name         String
  calories     Float
  proteinG     Float    @default(0)
  carbsG       Float    @default(0)
  fatG         Float    @default(0)
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedOn])
  @@index([coupleId])
  @@map("nutrition_logs")
}

// ─── Lifestyle: Exercise ─────────────────────────────────────

model ExerciseLog {
  id             String   @id @default(uuid())
  userId         String
  coupleId       String?
  loggedOn       DateTime @db.Date
  type           String   // CARDIO | STRENGTH | YOGA | SPORTS | OTHER
  name           String
  durationMins   Int
  caloriesBurned Float?
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedOn])
  @@index([coupleId])
  @@map("exercise_logs")
}

// ─── Lifestyle: Sleep ────────────────────────────────────────

model SleepLog {
  id           String   @id @default(uuid())
  userId       String
  coupleId     String?
  date         DateTime @db.Date
  bedtimeAt    DateTime
  wakeAt       DateTime
  durationMins Int
  quality      Int      // 1-5 scale
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([coupleId])
  @@map("sleep_logs")
}

// ─── Lifestyle: Habits ───────────────────────────────────────

model Habit {
  id          String   @id @default(uuid())
  userId      String
  coupleId    String?
  name        String
  description String?
  targetDays  Int      @default(7) // per week
  isShared    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]

  @@index([userId])
  @@index([coupleId])
  @@map("habits")
}

model HabitLog {
  id        String   @id @default(uuid())
  habitId   String
  userId    String
  loggedOn  DateTime @db.Date
  completed Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, userId, loggedOn])
  @@index([habitId])
  @@index([userId, loggedOn])
  @@map("habit_logs")
}

// ─── Couple: Chat ────────────────────────────────────────────

enum MessageType {
  TEXT
  LIST
  REMINDER
  AI_RESPONSE
  IMAGE
  VOICE
}

model CoupleMessage {
  id         String      @id @default(uuid())
  coupleId   String
  senderId   String
  type       MessageType @default(TEXT)
  content    String      @db.Text
  /// Base64-encoded AES-GCM IV — present only when `encrypted` is true.
  iv         String?
  /// True when `content` is AES-256-GCM ciphertext rather than plaintext.
  encrypted  Boolean     @default(false)
  payload    Json?       // structured data for LIST/REMINDER types
  reminderAt DateTime?
  readBy     String[]    @default([])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([coupleId, createdAt])
  @@index([senderId])
  @@map("couple_messages")
}

// ─── Travel ──────────────────────────────────────────────────

enum TripStatus {
  PLANNING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Trip {
  id          String     @id @default(uuid())
  userId      String
  coupleId    String?
  name        String
  destination String
  startDate   DateTime   @db.Date
  endDate     DateTime   @db.Date
  budget      Float?
  status      TripStatus @default(PLANNING)
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  itineraryItems TripItineraryItem[]
  expenses       TripExpense[]
  checklistItems TripChecklist[]

  @@index([userId])
  @@index([coupleId])
  @@map("trips")
}

model TripItineraryItem {
  id          String   @id @default(uuid())
  tripId      String
  day         Int      // day number (1, 2, 3...)
  time        String?  // "14:00" optional
  title       String
  description String?
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("trip_itinerary_items")
}

model TripExpense {
  id        String   @id @default(uuid())
  tripId    String
  userId    String
  title     String
  amount    Float
  currency  String   @default("INR")
  category  String?
  paidBy    String?  // userId of payer
  splitWith String[] @default([])
  date      DateTime @db.Date
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([userId])
  @@map("trip_expenses")
}

model TripChecklist {
  id         String   @id @default(uuid())
  tripId     String
  userId     String
  item       String
  packed     Boolean  @default(false)
  assignedTo String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@map("trip_checklist")
}

// ─── AI Data Chat History ─────────────────────────────────────

/** One conversation thread in the "Chat with your Couple data" AI assistant. */
model CoupleChat {
  id        String          @id @default(uuid())
  coupleId  String
  title     String          @default("New chat")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  messages  CoupleChatMsg[]

  @@index([coupleId])
  @@map("couple_chats")
}

/** One message (user or assistant) within a CoupleChat thread. */
model CoupleChatMsg {
  id        String     @id @default(uuid())
  chatId    String
  role      String     // "user" | "assistant"
  content   String     @db.Text
  /// Base64-encoded AES-GCM IV — present only when `encrypted` is true.
  iv        String?
  /// True when `content` is AES-256-GCM ciphertext rather than plaintext.
  encrypted Boolean    @default(false)
  createdAt DateTime   @default(now())

  chat CoupleChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@map("couple_chat_messages")
}

// ─── Push Notification Device Tokens ─────────────────────────

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String   // "android" | "ios" | "web"
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("device_tokens")
}
