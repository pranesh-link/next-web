// Personal CFO — Prisma Schema
// All models use UUID primary keys with proper relations and indexes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url configured in prisma.config.ts
}

// ─── NextAuth Models ────────────────────────────────────────

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Core Models ────────────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  name           String?
  email          String   @unique
  emailVerified  DateTime?
  image          String?
  currency       String   @default("INR")
  monthlyIncome  Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // NextAuth relations
  accounts_auth  Account[]
  sessions       Session[]

  // Finance relations
  accounts       FinancialAccount[]
  transactions   Transaction[]
  budgets        Budget[]
  loans          Loan[]
  savingsGoals   SavingsGoal[]

  // Couple relations
  coupleMembers  CoupleMember[]

  @@map("users")
}

model FinancialAccount {
  id        String   @id @default(uuid())
  userId    String
  name      String
  type      AccountType
  balance   Float    @default(0)
  coupleId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@map("financial_accounts")
}

enum AccountType {
  BANK
  CASH
  CREDIT_CARD
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String
  accountId   String
  amount      Float
  type        TransactionType
  category    String
  description String?
  date        DateTime
  coupleId    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  account FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
  @@index([userId, category])
  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Budget {
  id       String @id @default(uuid())
  userId   String
  category String
  limit    Float
  month    String // "2026-03" format
  coupleId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, month])
  @@index([userId])
  @@index([userId, month])
  @@map("budgets")
}

model Loan {
  id               String   @id @default(uuid())
  userId           String
  name             String
  principal        Float
  interestRate     Float
  tenureMonths     Int
  emiAmount        Float
  startDate        DateTime
  remainingBalance Float
  coupleId         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("loans")
}

model SavingsGoal {
  id            String    @id @default(uuid())
  userId        String
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  deadline      DateTime?
  coupleId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("savings_goals")
}

// ─── Couple Models ──────────────────────────────────────────

model Couple {
  id        String         @id @default(uuid())
  name      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  members   CoupleMember[]
  invites   CoupleInvite[]
}

model CoupleMember {
  id        String   @id @default(uuid())
  coupleId  String
  userId    String
  role      String   @default("OWNER")
  joinedAt  DateTime @default(now())
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([coupleId, userId])
  @@map("couple_members")
}

model CoupleInvite {
  id        String   @id @default(uuid())
  coupleId  String
  email     String
  invitedBy String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@map("couple_invites")
}
