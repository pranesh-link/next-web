# ─── Public (exposed to client) ─────────────────────────
NEXT_PUBLIC_SITE_URL="https://pranesh.link"
NEXT_PUBLIC_REVALIDATE=60

# ─── Database (Prisma Postgres) ─────────────────────────
DATABASE_URL="postgres://user:password@db.prisma.io:5432/postgres?sslmode=require"
DIRECT_DATABASE_URL="postgres://user:password@db.prisma.io:5432/postgres?sslmode=require"

# ─── Auth.js (NextAuth v5) ──────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3737"
AUTH_BASE_URL="http://localhost:3737"

# ─── Google OAuth ───────────────────────────────────────
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# ─── AI / LLM ──────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"
OPENROUTER_API_KEY="sk-or-v1-your-openrouter-key"

# ─── Redis (Upstash) ───────────────────────────────────
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ─── Cron Jobs ──────────────────────────────────────────
CRON_SECRET="generate-with: openssl rand -hex 32"
