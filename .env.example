# ─── Public (exposed to client) ─────────────────────────
NEXT_PUBLIC_SITE_URL="https://pranesh.link"
NEXT_PUBLIC_REVALIDATE=60

# ─── Database (Supabase Postgres) ───────────────────────
# DATABASE_URL → existing connection string (untouched, used by Prisma)
# Keep this exactly as it is until Drizzle migration is complete.
DATABASE_URL="postgres://postgres.xxxxx:password@aws-0-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require"

# DATABASE_URL_POOLER → Supabase Transaction Pooler (port 6543)
# Used ONLY by the Drizzle client (db/index.ts) during migration.
# After migration is verified, this replaces DATABASE_URL and this var is removed.
# Get from: Supabase Dashboard → Settings → Database → Connection Pooling → Transaction
DATABASE_URL_POOLER="postgres://postgres.xxxxx:password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# DIRECT_DATABASE_URL → direct connection (port 5432, no pooler)
# Used by Prisma CLI and drizzle-kit for migrations/introspection only.
# Get from: Supabase Dashboard → Settings → Database → Connection String
DIRECT_DATABASE_URL="postgres://postgres.xxxxx:password@aws-0-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require"

# ─── Auth.js (NextAuth v5) ──────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3737"
AUTH_BASE_URL="http://localhost:3737"

# ─── Google OAuth ───────────────────────────────────────
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# ─── AI / LLM ──────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"
OPENROUTER_API_KEY="sk-or-v1-your-openrouter-key"

# ─── Redis (Upstash) ───────────────────────────────────
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ─── Cron Jobs ──────────────────────────────────────────
CRON_SECRET="generate-with: openssl rand -hex 32"

# ─── Admin Dashboard ────────────────────────────────────
ADMIN_EMAIL="prans1991@gmail.com"

# ─── Mobile App ─────────────────────────────────────────
NEXT_PUBLIC_APP_STORE_LINK="https://play.google.com/store/apps/details?id=link.pranesh.luvverse"
